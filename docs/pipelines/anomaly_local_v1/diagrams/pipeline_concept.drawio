        <mxCell id="step7_container" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefaf3;strokeColor=#c47a10;strokeWidth=1;arcSize=8;" value="" vertex="1">
          <mxGeometry x="40" y="1445" width="820" height="218" as="geometry" />
        </mxCell>
        <mxCell id="step7_h" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef8ef;strokeColor=#c47a10;strokeWidth=2;fontSize=11;align=center;verticalAlign=middle;spacing=6;arcSize=8;" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;7. Scoring und Labels&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;i style=&quot;color:#555;&quot;&gt;&amp;quot;Wie auffaellig ist der Punkt - und wie sicher sind wir uns?&amp;quot;&lt;/i&gt;" vertex="1">
          <mxGeometry x="40" y="1445" width="820" height="44" as="geometry" />
        </mxCell>
        <mxCell id="step7_a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c47a10;strokeWidth=1.5;fontSize=10;align=center;verticalAlign=middle;arcSize=8;spacing=6;" value="&lt;b style=&quot;color:#c47a10;font-size:12px;&quot;&gt;Auffaelligkeits-Score&lt;/b&gt;&lt;br&gt;Cluster-Abweichung, lokale Lage, Regelverstoesse&lt;br&gt;&lt;span style=&quot;color:#888;font-size:9px;&quot;&gt;0.60 * Cluster + 0.25 * Lokal + 0.15 * Regeln&lt;/span&gt;" vertex="1">
          <mxGeometry x="50" y="1497" width="395" height="80" as="geometry" />
        </mxCell>
        <mxCell id="step7_b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a6b8a;strokeWidth=1.5;fontSize=10;align=center;verticalAlign=middle;arcSize=8;spacing=6;" value="&lt;b style=&quot;color:#1a6b8a;font-size:12px;&quot;&gt;Vertrauens-Score&lt;/b&gt;&lt;br&gt;Cross-Track, Stuetzung, Signalqualitaet&lt;br&gt;&lt;span style=&quot;color:#888;font-size:9px;&quot;&gt;0.45*(1-Auff) + 0.25*Cross + 0.20*Stuetze + 0.10*Signal&lt;/span&gt;" vertex="1">
          <mxGeometry x="455" y="1497" width="395" height="80" as="geometry" />
        </mxCell>
        <mxCell id="step7_label_intro" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#444444;" value="Daraus folgt das Label (anhand des Vertrauens-Score):" vertex="1">
          <mxGeometry x="50" y="1583" width="800" height="18" as="geometry" />
        </mxCell>
        <mxCell id="step7_normal" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;fontSize=10;align=center;verticalAlign=middle;arcSize=40;fontColor=#2d6e4e;" value="&lt;b&gt;normal&lt;/b&gt;  &amp;gt;= 0.70" vertex="1">
          <mxGeometry x="205" y="1605" width="145" height="22" as="geometry" />
        </mxCell>
        <mxCell id="step7_suspect" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1.5;fontSize=10;align=center;verticalAlign=middle;arcSize=40;fontColor=#7f6000;" value="&lt;b&gt;suspect&lt;/b&gt;  0.40 - 0.69" vertex="1">
          <mxGeometry x="365" y="1605" width="170" height="22" as="geometry" />
        </mxCell>
        <mxCell id="step7_outlier" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1.5;fontSize=10;align=center;verticalAlign=middle;arcSize=40;fontColor=#a0282a;" value="&lt;b&gt;outlier&lt;/b&gt;  &amp;lt; 0.40" vertex="1">
