        <mxCell id="fc_coh_pen" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7b2d8e;strokeWidth=1;fontSize=10;align=center;verticalAlign=middle;arcSize=8;spacing=4;" value="&lt;b style=&quot;color:#7b2d8e;font-size:11px;&quot;&gt;coherence_penalty&lt;/b&gt;&lt;br&gt;bestraft schwache Reflexionen&lt;br&gt;&lt;span style=&quot;color:#c47a10;font-size:9px;&quot;&gt;berechnet: 1.0 - insar_points.coherence&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color:#888;font-size:9px;&quot;&gt;-&amp;gt; Schritt 4 (Cluster-Vektor)&lt;/span&gt;" vertex="1">
