        </mxCell>
        <mxCell id="fc_ts_step" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7b2d8e;strokeWidth=1;fontSize=10;align=center;verticalAlign=middle;arcSize=8;spacing=4;" value="&lt;b style=&quot;color:#7b2d8e;font-size:11px;&quot;&gt;ts_primary_step_abs&lt;/b&gt;&lt;br&gt;Groesster einzelner Sprung in der Zeitreihe&lt;br&gt;&lt;span style=&quot;color:#c47a10;font-size:9px;&quot;&gt;berechnet: max(|disp[i] - disp[i-1]|)&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color:#888;font-size:9px;&quot;&gt;-&amp;gt; Schritt 7 (rule_penalty: unsupported_step)&lt;/span&gt;" vertex="1">
          <mxGeometry x="80" y="300" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="fc_ts_rough" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7b2d8e;strokeWidth=1;fontSize=10;align=center;verticalAlign=middle;arcSize=8;spacing=4;" value="&lt;b style=&quot;color:#7b2d8e;font-size:11px;&quot;&gt;ts_roughness&lt;/b&gt;&lt;br&gt;Mittlere absolute 1.-Differenz (Jitter)&lt;br&gt;&lt;span style=&quot;color:#c47a10;font-size:9px;&quot;&gt;berechnet: mean(|diff(displacement)|)&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color:#888;font-size:9px;&quot;&gt;-&amp;gt; Schritt 7 (local_deviation)&lt;/span&gt;" vertex="1">
