        </mxCell>
        <mxCell id="step7_warum" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#c47a10;fontStyle=2;" value="&lt;b&gt;Warum:&lt;/b&gt; &amp;quot;Wie auffaellig&amp;quot; und &amp;quot;wie verlaesslich ist die Aussage&amp;quot; sind unterschiedliche Fragen - sie muessen getrennt sichtbar bleiben." vertex="1">
          <mxGeometry x="50" y="1635" width="800" height="24" as="geometry" />
        </mxCell>
        <mxCell id="output_panel" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#82b366;strokeWidth=2;fontSize=11;align=left;verticalAlign=middle;spacing=12;arcSize=10;" value="&lt;center&gt;&lt;b style=&quot;font-size:14px;color:#1b5e20;&quot;&gt;Was liefert diese Pipeline fachlich?&lt;/b&gt;&lt;/center&gt;&lt;br&gt;&amp;#8226;&amp;nbsp; &lt;b&gt;Pro Punkt&lt;/b&gt; - ein Label und zwei Scores (Auffaelligkeit, Vertrauen)&lt;br&gt;&amp;#8226;&amp;nbsp; &lt;b&gt;Pro Cluster&lt;/b&gt; - raeumliche Huellen und Mediankennzahlen je Gebaeude+Track&lt;br&gt;&amp;#8226;&amp;nbsp; &lt;b&gt;Pro Gebaeude&lt;/b&gt; - konsolidiertes Bewegungsbild mit Vertrauensband&lt;br&gt;&amp;#8226;&amp;nbsp; &lt;b&gt;Diagnostik&lt;/b&gt; - Hinweise auf Fehlzuordnungen und Nachbarschafts-Ereignisse" vertex="1">
          <mxGeometry x="40" y="1683" width="820" height="160" as="geometry" />
        </mxCell>
