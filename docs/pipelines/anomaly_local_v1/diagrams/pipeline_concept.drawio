        </mxCell>
        <mxCell id="fc_acceleration" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7b2d8e;strokeWidth=1;fontSize=10;align=center;verticalAlign=middle;arcSize=8;spacing=4;" value="&lt;b style=&quot;color:#7b2d8e;font-size:11px;&quot;&gt;acceleration&lt;/b&gt;&lt;br&gt;Aenderung der Bewegungsrate ueber Zeit&lt;br&gt;&lt;span style=&quot;color:#2d6e4e;font-size:9px;&quot;&gt;direkt: insar_points.acceleration&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color:#888;font-size:9px;&quot;&gt;-&amp;gt; Schritt 4 (Cluster-Vektor)&lt;/span&gt;" vertex="1">
          <mxGeometry x="350" y="190" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="fc_ts_slope" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7b2d8e;strokeWidth=1;fontSize=10;align=center;verticalAlign=middle;arcSize=8;spacing=4;" value="&lt;b style=&quot;color:#7b2d8e;font-size:11px;&quot;&gt;ts_slope&lt;/b&gt;&lt;br&gt;Linearer Trend der Zeitreihe (mm/a)&lt;br&gt;&lt;span style=&quot;color:#c47a10;font-size:9px;&quot;&gt;berechnet: polyfit(date, displacement, deg=1)&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color:#888;font-size:9px;&quot;&gt;-&amp;gt; Schritt 7 (local_deviation)&lt;/span&gt;" vertex="1">
          <mxGeometry x="620" y="190" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="fc_ts_residual" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7b2d8e;strokeWidth=1;fontSize=10;align=center;verticalAlign=middle;arcSize=8;spacing=4;" value="&lt;b style=&quot;color:#7b2d8e;font-size:11px;&quot;&gt;ts_residual_std&lt;/b&gt;&lt;br&gt;Streuung nach Trend-Entfernung&lt;br&gt;&lt;span style=&quot;color:#c47a10;font-size:9px;&quot;&gt;berechnet: std(displacement - linearer Trend)&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color:#888;font-size:9px;&quot;&gt;-&amp;gt; Schritt 7 (rule_penalty)&lt;/span&gt;" vertex="1">
