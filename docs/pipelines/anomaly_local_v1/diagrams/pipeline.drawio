        <mxCell id="scoring" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef8ef;strokeColor=#c47a10;strokeWidth=2;fontSize=12;align=center;" value="&lt;b&gt;_score_records&lt;/b&gt;&lt;br&gt;rule_penalty: nearest/directional assignment, high velocity_std, unstable amplitude, unsupported step, weak local support, cross-track mismatch&lt;br&gt;anomaly_score = 0.60 cluster_outlier + 0.25 local_deviation + 0.15 rule_penalty&lt;br&gt;quality_score = 0.45 (1-anomaly) + 0.25 cross_track + 0.20 kept_support + 0.10 signal_quality&lt;br&gt;Labels: normal &gt;= 0.70, suspect 0.40-0.69, outlier &lt; 0.40 or gate-excluded" vertex="1">
