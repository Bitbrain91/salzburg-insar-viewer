<mxfile host="app.diagrams.net" agent="Codex" version="29.6.4">
  <diagram name="anomaly_local_v1 Pipeline (current simplified)" id="simple-current">
    <mxGraphModel dx="1188" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontColor=#1a1a2e;" value="&lt;b&gt;anomaly_local_v1 - aktuelle Pipeline&lt;/b&gt;" vertex="1">
          <mxGeometry x="210" y="20" width="580" height="36" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#777777;" value="Code-abgeleitet aus backend/app/ml/pipelines/anomaly_local_v1.py und track_geometry.py, Stand 2026-04-28" vertex="1">
          <mxGeometry x="180" y="56" width="640" height="30" as="geometry" />
        </mxCell>
        <mxCell id="input" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=12;align=center;" value="&lt;b&gt;Run-Kontext + PostGIS&lt;/b&gt;&lt;br&gt;BBox, optional track, source=gba&lt;br&gt;insar_points / timeseries / amplitude&lt;br&gt;gba_buildings + building_terrain_context" vertex="1">
          <mxGeometry x="300" y="110" width="400" height="92" as="geometry" />
        </mxCell>
        <mxCell id="step1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f7ff;strokeColor=#16537e;strokeWidth=2;fontSize=12;align=center;spacing=8;arcSize=8;" value="&lt;font style=&quot;font-size:15px&quot;&gt;&lt;b&gt;1. Punktzuordnung&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;Prioritaet: within -&gt; directional_buffer -&gt; nearest &lt;= 15 m&lt;br&gt;Directional buffer nutzt zentrale 2D-Track-Geometrie:&lt;br&gt;Track 44/A sensor-bearing 261.4 deg, Track 95/D sensor-bearing 101.5 deg&lt;br&gt;range_shift = range_offset * (range_dx, range_dy)" vertex="1">
          <mxGeometry x="240" y="250" width="520" height="128" as="geometry" />
        </mxCell>
        <mxCell id="step2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f0ff;strokeColor=#7b2d8e;strokeWidth=2;fontSize=12;align=center;spacing=8;arcSize=8;" value="&lt;font style=&quot;font-size:15px&quot;&gt;&lt;b&gt;2. Feature-Berechnung&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;Zeitreihe: valid epochs, slope, residuals, primary step&lt;br&gt;Amplitude: CV und Spike-Rate, optional je Track&lt;br&gt;Gebaeude/Track: along_look, cross_look, height_rank, local_density, step_support&lt;br&gt;Terrain: slope_mean, slope_max, relief_range" vertex="1">
          <mxGeometry x="240" y="425" width="520" height="124" as="geometry" />
        </mxCell>
        <mxCell id="step3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef0ef;strokeColor=#ae4132;strokeWidth=2;fontSize=12;align=center;spacing=8;arcSize=8;" value="&lt;font style=&quot;font-size:15px&quot;&gt;&lt;b&gt;3. Gate-Rules&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;Harte Ausschluesse vor Clustering:&lt;br&gt;kein Gebaeude, &lt; 24 gueltige Epochen, &lt; 50% Track-Abdeckung,&lt;br&gt;coherence &lt; max(0.45, track_p05)&lt;br&gt;Gate-Punkte bleiben als excluded/outlier visualisierbar." vertex="1">
          <mxGeometry x="240" y="595" width="520" height="118" as="geometry" />
        </mxCell>
        <mxCell id="step4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0faf0;strokeColor=#2d6e4e;strokeWidth=2;fontSize=12;align=center;spacing=8;arcSize=8;" value="&lt;font style=&quot;font-size:15px&quot;&gt;&lt;b&gt;4. Lokales Clustering pro Gebaeude x Track&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt; 3 kept: insufficient_support&lt;br&gt;3-5 kept: Small-N-Fallback auf local_deviation&lt;br&gt;&gt;= 6 kept: HDBSCAN; OPTICS-Fallback wenn hdbscan fehlt&lt;br&gt;Matrix: along, cross, height_rank, velocity, acceleration, coherence_penalty" vertex="1">
          <mxGeometry x="240" y="760" width="520" height="128" as="geometry" />
        </mxCell>
        <mxCell id="step5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef8fb;strokeColor=#1a6b8a;strokeWidth=2;fontSize=12;align=center;spacing=8;arcSize=8;" value="&lt;font style=&quot;font-size:15px&quot;&gt;&lt;b&gt;5. Building- und Cross-Track-Rollups&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;Main Cluster je Track, median vertical proxy = velocity / cos(incidence)&lt;br&gt;Track 44 vs Track 95 agreement mit allowed_diff = 1.0 + 0.15 * slope_mean&lt;br&gt;Building status, reliability band, weak secondary track, differential_motion_flag&lt;br&gt;Diese Rollups entstehen vor dem finalen Punkt-Scoring." vertex="1">
          <mxGeometry x="240" y="935" width="520" height="132" as="geometry" />
        </mxCell>
        <mxCell id="step6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e8;strokeColor=#c47a10;strokeWidth=2;fontSize=12;align=center;spacing=8;arcSize=8;" value="&lt;font style=&quot;font-size:15px&quot;&gt;&lt;b&gt;6. Neighbourhood-Diagnostik&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;Naechste Gebaeude im 25-m-Radius, max. 8 Kandidaten&lt;br&gt;Cluster-Fit gegen eigene und Nachbar-Cluster&lt;br&gt;Misassignment-Flags und Neighbour-Event-Signale werden in meta abgelegt." vertex="1">
          <mxGeometry x="240" y="1115" width="520" height="112" as="geometry" />
        </mxCell>
        <mxCell id="step7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef8ef;strokeColor=#c47a10;strokeWidth=2;fontSize=12;align=center;spacing=8;arcSize=8;" value="&lt;font style=&quot;font-size:15px&quot;&gt;&lt;b&gt;7. Scoring, Labels, Persistenz&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;anomaly_score = 60% cluster_outlier + 25% local_deviation + 15% rule_penalty&lt;br&gt;quality_score = 45% (1-anomaly) + 25% cross_track + 20% kept_support + 10% signal_quality&lt;br&gt;Labels: normal / suspect / outlier; Ergebnisse nach ml_point_results.meta" vertex="1">
          <mxGeometry x="240" y="1275" width="520" height="132" as="geometry" />
        </mxCell>
        <mxCell id="runner_note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;fontSize=11;align=center;arcSize=8;" value="Runner schreibt Status, MLflow-Parameter, Run-Metriken und Summary-Artifact; danach assign_building_colors fuer die UI." vertex="1">
          <mxGeometry x="730" y="126" width="220" height="72" as="geometry" />
        </mxCell>
        <mxCell id="ui_note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=center;arcSize=8;" value="API/UI nutzen gespeicherte Meta-Daten fuer Punkte, Gebaeude-Rollups, Candidate Areas, Cluster-Hulls und Inspector-Diagnostik." vertex="1">
